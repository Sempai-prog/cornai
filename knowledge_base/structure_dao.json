      "nom_standard": "Avis d'Appel d'Offres (AAO)",
      "contenu": "Résumé officiel de l'Appel d'Offres tel que publié par voie d'affichage, dans les journaux ou en ligne.",
      "infos_a_extraire": [
        "objet_du_marche",
        "maitre_ouvrage",
        "cout_previsionnel",
        "delai_execution_ou_livraison",
        "montant_caution_soumission",
        "date_et_heure_limite_depot",
        "lieu_depot"
      ],
      "present_dans": "100% des DAO",
