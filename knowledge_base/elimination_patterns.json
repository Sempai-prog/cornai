          "formulations_sources": [
            "Absence d’un prix unitaire quantifié dans l’offre financière"
          ],
          "regex": "(?i)(absence|omission|défaut|manque).{0,40}(prix[- ]?unitaire[- ]?quantifié)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Élimination directe de l'offre globale",
