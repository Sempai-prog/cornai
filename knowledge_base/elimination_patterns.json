          ],
          "regex": "(?i)(non[- ]?respect|mauvais).{0,30}(format[- ]?de[- ]?fichier[s]?|format[- ]?numérique).{0,40}(en[- ]?ligne|électronique|coleps)?",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Impossibilité de télécharger l'offre par la commission, élimination de fait",
