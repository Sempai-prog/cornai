        },
        {
          "id": "elim_financier_003",
          "critere_canonique": "Absence de l'offre financière témoin",
          "formulations_sources": [
            "Absence de l'offre financière témoin"
          ],
          "regex": "(?i)(absence|défaut|manque).{0,40}(offre[- ]?financière[- ]?témoin|pli[- ]?témoin)",
          "types_marches_concernes": ["prestations_intellectuelles", "assurances", "travaux (si AONR)"],
          "consequence": "Irrecevabilité de l'offre",
          "rattrapable": false,
          "piece_liee": null,
          "action_app": {
            "checklist": true,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_colisage_temoin"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        }
      ]
    },
    {
      "id": "elim_technique",
      "nom": "Offre Technique",
      "criteres": [
        {
          "id": "elim_tech_001",
          "critere_canonique": "Note technique inférieure au seuil éliminatoire",
          "formulations_sources": [
            "Note technique inférieure à X points sur 100",
            "Non-respect d’au moins X critères essentiels sur Y"
          ],
          "regex": "(?i)(non[- ]?respect).{0,40}(critères[- ]?essentiels)|(note[- ]?technique[- ]?inférieure)|(n'avoir[- ]?pas[- ]?obtenu).{0,30}(critères)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Non-ouverture de l'offre financière",
          "rattrapable": false,
          "piece_liee": null,
          "action_app": {
            "checklist": false,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_score_tech_faible"
          },
          "references_legales": ["Article 15.1 du RPAO", "Grille d'évaluation"]
        },
        {
          "id": "elim_tech_002",
          "critere_canonique": "Absence de prospectus en couleur / Catalogue",
          "formulations_sources": [
            "absence de prospectus de couleur dans l’original et toutes les copies accompagné de catalogue, dessin ou fiche technique"
          ],
          "regex": "(?i)(absence|défaut|manque).{0,50}(prospectus|catalogue|fiche[- ]?technique|dessin)",
          "types_marches_concernes": ["fournitures"],
          "consequence": "Élimination de la proposition technique",
          "rattrapable": false,
          "piece_liee": null,
          "action_app": {
            "checklist": true,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_upload_prospectus"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        },
        {
          "id": "elim_tech_003",
          "critere_canonique": "Absence d'agrément ou d'autorisation du fabricant",
          "formulations_sources": [
            "absence de l’agrément ou de l’autorisation du fournisseur délivré par le fabricant"
          ],
          "regex": "(?i)(absence|défaut|manque).{0,50}(agrément|autorisation[- ]?du[- ]?fabricant|distributeur[- ]?agréé)",
          "types_marches_concernes": ["fournitures"],
          "consequence": "Élimination",
          "rattrapable": false,
          "piece_liee": "piece_009",
          "action_app": {
            "checklist": true,
            "alerte_priorite": "critique",
            "message_template": "whatsapp_autorisation_fabricant"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        },
        {
          "id": "elim_tech_004",
          "critere_canonique": "Agent public non libéré de l'Administration",
          "formulations_sources": [
            "Tout agent public listé parmi le personnel et qui n’a pas présenté tous les documents susceptibles de justifier sa libération de l’Administration sera considéré comme non valable"
          ],
          "regex": "(?i)(agent[- ]?public|fonctionnaire).{0,60}(libération|disponibilité|mise[- ]?en[- ]?disponibilité)",
          "types_marches_concernes": ["prestations_intellectuelles", "travaux"],
          "consequence": "Expert évalué à 0 point (peut entraîner une chute sous le seuil éliminatoire global)",
          "rattrapable": false,
          "piece_liee": null,
          "action_app": {
            "checklist": true,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_cv_fonctionnaire"
          },
          "references_legales": ["Note de bas de page de la Grille d'évaluation des experts"]
        }
      ]
    },
    {
      "id": "elim_forme",
      "nom": "Vices de Forme et Dématérialisation",
      "criteres": [
        {
          "id": "elim_forme_001",
