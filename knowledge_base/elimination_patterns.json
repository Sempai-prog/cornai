  "regle_dor": "Un critère ne peut être à la fois éliminatoire et essentiel",
  "categories": [
    {
      "id": "elim_admin",
      "nom": "Défauts Administratifs",
      "criteres": [
        {
          "id": "elim_admin_001",
          "critere_canonique": "Absence du cautionnement de soumission à l'ouverture",
          "formulations_sources": [
            "Absence de la caution de soumission",
            "absence ou non-conformité du cautionnement de soumission à l’ouverture des plis"
          ],
          "regex": "(?i)(absence|défaut|manque|non[- ]?(présentation|production|fourniture|conformité)).{0,40}(caution|cautionnement|garantie).{0,30}(soumission)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Rejet immédiat et systématique sans rattrapage",
          "rattrapable": false,
          "piece_liee": "piece_001",
          "action_app": {
            "checklist": true,
            "alerte_priorite": "critique",
            "message_template": "whatsapp_caution_001"
          },
          "references_legales": ["Article 15.1 du RPAO", "Article 19.7 du RGAO"]
        },
        {
          "id": "elim_admin_002",
          "critere_canonique": "Non-production d'une pièce administrative au-delà de 48h",
          "formulations_sources": [
            "Non production au-delà du délai de 48h après l’ouverture des plis, d’une pièce du dossier administratif jugée non conforme ou absente"
          ],
          "regex": "(?i)(non[- ]?production|absence|défaut).{0,60}(48[- ]?h|quarante[- ]?huit heures|48 heures).{0,50}(pièce|dossier[- ]?administratif|non[- ]?conforme)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Rejet du dossier administratif après expiration du sursis",
          "rattrapable": true,
          "piece_liee": "pieces_administratives_standard",
          "action_app": {
            "checklist": true,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_sursis_48h"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        }
      ]
    },
    {
      "id": "elim_ethique",
      "nom": "Ordre Général, Éthique et Fraude",
      "criteres": [
        {
          "id": "elim_ethique_001",
          "critere_canonique": "Fausses déclarations ou pièces falsifiées",
          "formulations_sources": [
            "Fausses déclarations, manœuvres frauduleuses ou falsification des pièces"
          ],
          "regex": "(?i)(fausse[s]?[- ]?déclaration[s]?|manœuvre[s]?[- ]?frauduleuse[s]?|pièce[s]?[- ]?falsifiée[s]?|falsification|substitution)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Élimination de l'offre, risque de suspension de la commande publique par l'ARMP",
          "rattrapable": false,
          "piece_liee": null,
          "action_app": {
            "checklist": false,
            "alerte_priorite": "critique",
            "message_template": "whatsapp_alerte_fraude"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        },
        {
          "id": "elim_ethique_002",
          "critere_canonique": "Absence de déclaration de non-abandon",
          "formulations_sources": [
            "Absence d’une déclaration sur l’honneur de n’avoir pas abandonné de chantier durant les trois dernières années",
            "absence de l’attestation de non abandon de marchés au cours des trois dernières années"
          ],
          "regex": "(?i)(absence|défaut|manque).{0,40}(déclaration|attestation).{0,40}(non[- ]?abandon|abandonné).{0,30}(chantier|marché|prestation|travaux).{0,40}(trois|3)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Élimination immédiate",
          "rattrapable": false,
          "piece_liee": "piece_002",
          "action_app": {
            "checklist": true,
            "alerte_priorite": "elevee",
            "message_template": "whatsapp_gen_non_abandon"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        },
        {
          "id": "elim_ethique_003",
          "critere_canonique": "Absence de la charte d'intégrité signée",
          "formulations_sources": [
            "absence de la charte d’intégrité datée et signée"
          ],
          "regex": "(?i)(absence|défaut|manque).{0,40}(charte[- ]?d'intégrité)",
          "types_marches_concernes": ["travaux", "fournitures", "services_quantifiables", "prestations_intellectuelles", "assurances"],
          "consequence": "Élimination",
          "rattrapable": false,
          "piece_liee": "piece_003",
          "action_app": {
            "checklist": true,
            "alerte_priorite": "moyenne",
            "message_template": "whatsapp_signer_charte"
          },
          "references_legales": ["Article 15.1 du RPAO"]
        }
      ]
    },
    {
      "id": "elim_financier",
      "nom": "Offre Financière",
