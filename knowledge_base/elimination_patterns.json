          "formulations_sources": [
            "Présence d’informations financières dans l’offre technique"
          ],
          "regex": "(?i)(présence|insertion|inclusion).{0,40}(informations[- ]?financières|prix|montant).{0,40}(offre[- ]?technique|dossier[- ]?technique)",
